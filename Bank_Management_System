#include <iostream>
#include <fstream>
#include <string>
using namespace std;

class BankAccount
{
public:
    int accNo;
    string name;
    double balance;

    void createAccount()
    {
        cout << "Enter Account Number: ";
        cin >> accNo;

        cin.ignore();

        cout << "Enter Customer Name: ";
        getline(cin, name);

        cout << "Enter Initial Deposit: ";
        cin >> balance;
    }
};

// Check if account exists
bool accountExists(int accNo)
{
    ifstream file("accounts.txt");

    BankAccount acc;
    string temp;

    while (getline(file, temp, '|'))
    {
        acc.accNo = stoi(temp);

        getline(file, acc.name, '|');

        getline(file, temp);
        acc.balance = stod(temp);

        if (acc.accNo == accNo)
        {
            file.close();
            return true;
        }
    }

    file.close();
    return false;
}

// Create account
void createNewAccount()
{
    BankAccount acc;
    acc.createAccount();

    if (accountExists(acc.accNo))
    {
        cout << "\nAccount already exists.\n";
        return;
    }

    ofstream file("accounts.txt", ios::app);

    file << acc.accNo << "|"
         << acc.name << "|"
         << acc.balance << endl;

    file.close();

    cout << "\nAccount Created Successfully.\n";
}

// Display all accounts
void displayAccounts()
{
    ifstream file("accounts.txt");

    if (!file)
    {
        cout << "\nNo account records found.\n";
        return;
    }

    BankAccount acc;
    string temp;

    cout << "\n------------------------------------------\n";
    cout << "Acc No\tName\t\tBalance\n";
    cout << "------------------------------------------\n";

    while (getline(file, temp, '|'))
    {
        acc.accNo = stoi(temp);

        getline(file, acc.name, '|');

        getline(file, temp);
        acc.balance = stod(temp);

        cout << acc.accNo << "\t"
             << acc.name << "\t"
             << acc.balance << endl;
    }

    file.close();
}

// Balance inquiry
void checkBalance()
{
    int accNo;
    bool found = false;

    cout << "Enter Account Number: ";
    cin >> accNo;

    ifstream file("accounts.txt");

    BankAccount acc;
    string temp;

    while (getline(file, temp, '|'))
    {
        acc.accNo = stoi(temp);

        getline(file, acc.name, '|');

        getline(file, temp);
        acc.balance = stod(temp);

        if (acc.accNo == accNo)
        {
            cout << "\nAccount Holder : " << acc.name << endl;
            cout << "Current Balance : Rs. " << acc.balance << endl;

            found = true;
            break;
        }
    }

    if (!found)
    {
        cout << "\nAccount Not Found.\n";
    }

    file.close();
}

// Deposit money
void depositMoney()
{
    int accNo;
    double amount;
    bool found = false;

    cout << "Enter Account Number: ";
    cin >> accNo;

    cout << "Enter Amount to Deposit: ";
    cin >> amount;

    ifstream file("accounts.txt");
    ofstream tempFile("temp.txt");

    BankAccount acc;
    string temp;

    while (getline(file, temp, '|'))
    {
        acc.accNo = stoi(temp);

        getline(file, acc.name, '|');

        getline(file, temp);
        acc.balance = stod(temp);

        if (acc.accNo == accNo)
        {
            acc.balance += amount;
            found = true;
        }

        tempFile << acc.accNo << "|"
                 << acc.name << "|"
                 << acc.balance << endl;
    }

    file.close();
    tempFile.close();

    remove("accounts.txt");
    rename("temp.txt", "accounts.txt");

    if (found)
        cout << "\nDeposit Successful.\n";
    else
        cout << "\nAccount Not Found.\n";
}

// Withdraw money
void withdrawMoney()
{
    int accNo;
    double amount;
    bool found = false;

    cout << "Enter Account Number: ";
    cin >> accNo;

    cout << "Enter Amount to Withdraw: ";
    cin >> amount;

    ifstream file("accounts.txt");
    ofstream tempFile("temp.txt");

    BankAccount acc;
    string temp;

    while (getline(file, temp, '|'))
    {
        acc.accNo = stoi(temp);

        getline(file, acc.name, '|');

        getline(file, temp);
        acc.balance = stod(temp);

        if (acc.accNo == accNo)
        {
            found = true;

            if (amount <= acc.balance)
            {
                acc.balance -= amount;
                cout << "\nWithdrawal Successful.\n";
            }
            else
            {
                cout << "\nInsufficient Balance.\n";
            }
        }

        tempFile << acc.accNo << "|"
                 << acc.name << "|"
                 << acc.balance << endl;
    }

    file.close();
    tempFile.close();

    remove("accounts.txt");
    rename("temp.txt", "accounts.txt");

    if (!found)
        cout << "\nAccount Not Found.\n";
}

int main()
{
    int choice;

    do
    {
        cout << "\n===================================";
        cout << "\n      BANK MANAGEMENT SYSTEM";
        cout << "\n===================================";
        cout << "\n1. Create Account";
        cout << "\n2. Deposit Money";
        cout << "\n3. Withdraw Money";
        cout << "\n4. Check Balance";
        cout << "\n5. Display Accounts";
        cout << "\n6. Exit";

        cout << "\n\nEnter Choice: ";
        cin >> choice;

        switch (choice)
        {
        case 1:
            createNewAccount();
            break;

        case 2:
            depositMoney();
            break;

        case 3:
            withdrawMoney();
            break;

        case 4:
            checkBalance();
            break;

        case 5:
            displayAccounts();
            break;

        case 6:
            cout << "\nThank You!\n";
            break;

        default:
            cout << "\nInvalid Choice.\n";
        }

    } while (choice != 6);

    return 0;
}
